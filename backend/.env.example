# Database
DATABASE_URL=postgresql+asyncpg://mediation:mediation@localhost:5432/mediation_platform

# JWT
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS
FRONTEND_ORIGIN=http://localhost:5174

# Uploads
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=100
MAX_RESOURCE_SIZE_MB=500

# OAuth - redirect_uri는 코드에서 읽지 않음(프론트가 매번 계산해서 보냄).
# 아래는 각 Provider 콘솔에 "등록할 값"을 참고하기 위한 안내 주석.

# OAuth - Naver (콘솔 등록: http://localhost:5174/oauth/callback/naver)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OAuth - Kakao (콘솔 등록: http://localhost:5174/oauth/callback/kakao)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# OAuth - Google (콘솔 등록: http://localhost:5174/oauth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - Apple (Services ID). client_secret은 정적 값이 아니라 아래 3개 값으로
# 서버가 ES256 JWT를 매 호출마다 동적 서명한다(app/core/apple_auth.py).
# 콘솔 등록: http://localhost:8001/api/v1/auth/apple/form-callback (프론트가 아니라 백엔드 주소!)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
